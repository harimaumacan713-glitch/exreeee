rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidProfile(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is string &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1024)) &&
             (!('tier' in data) || (data.tier in ['VIP 1', 'VIP 2', 'VIP 3'])) &&
             (!('tradingFee' in data) || (data.tradingFee is number && data.tradingFee >= 0));
    }

    function isValidWallet(data) {
      return data.totalBalance is number && data.totalBalance >= 0 &&
             (!('pnl24h' in data) || data.pnl24h is number) &&
             (!('pnlPercent' in data) || data.pnlPercent is number);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'asset', 'side', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.asset is string && data.asset.size() <= 32 &&
             data.side in ['buy', 'sell'] &&
             data.status in ['open', 'completed', 'cancelled'] &&
             data.createdAt is string &&
             (!('price' in data) || (data.price is number && data.price >= 0)) &&
             (!('amount' in data) || (data.amount is number && data.amount >= 0)) &&
             (!('filled' in data) || (data.filled is number && data.filled >= 0));
    }

    // --- Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidProfile(incoming());
      allow update: if isOwner(userId) && isValidProfile(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().email == existing().email;
      
      // Wallet Summary
      match /wallet/summary {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidWallet(incoming());
      }
      
      // Holdings
      match /holdings/{assetId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(assetId);
      }
      
      // Orders
      match /orders/{orderId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(orderId) && isValidOrder(incoming());
        allow update: if isOwner(userId) && isValidId(orderId) && isValidOrder(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().side == existing().side &&
                      incoming().asset == existing().asset &&
                      (incoming().status != existing().status || incoming().filled != existing().filled);
      }
    }

    // --- Markets (Public) ---
    match /markets/{tickerId} {
      allow read: if true;
      allow write: if false; // System only or Admin
    }
  }
}
